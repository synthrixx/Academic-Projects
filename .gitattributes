# -------------------------------
# GitHub Linguist Configuration
# -------------------------------
# This file is used to make GitHub language statistics more accurate
# for academic projects containing MATLAB, Simulink, LTspice, PDFs,
# images, audio files, and generated GUI/export files.

# -------------------------------
# Documentation and report files
# -------------------------------
*.pdf linguist-documentation
*.md linguist-documentation
*.jpg linguist-documentation
*.jpeg linguist-documentation
*.png linguist-documentation
*.wav linguist-documentation

# -------------------------------
# MATLAB source files
# -------------------------------
*.m linguist-language=MATLAB
*.mlx linguist-language=MATLAB

# -------------------------------
# Arduino source file
# -------------------------------
# This file contains Arduino/C++ code, although it is saved as .txt.
**/Arduino_Project_Code.txt linguist-language=C++

# -------------------------------
# MATLAB App Designer / Simulink files
# -------------------------------
# These files are project/model files, not manually written HTML/CSS code.
*.mlapp linguist-generated
*.slx linguist-generated

# -------------------------------
# Tinkercad exported/saved webpage files
# -------------------------------
# These are automatically downloaded webpage assets, not project source code.
**/Tinkercad_link.html linguist-generated
**/Tinkercad_link_files/** linguist-generated

# -------------------------------
# Generated web-like files
# -------------------------------
*.html linguist-generated
*.htm linguist-generated
*.css linguist-generated
*.js linguist-generated

# -------------------------------
# LTspice simulation/schematic files
# -------------------------------
# GitHub does not normally show these as "LTspice".
# .asc files are often detected as AGS Script because Linguist associates .asc with AGS Script.
# Keep them excluded to avoid misleading language statistics.
*.asc linguist-generated
*.asy linguist-generated
*.cir linguist-generated
*.net linguist-generated

# Auto detect text files and perform LF normalization
* text=auto